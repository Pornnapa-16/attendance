# ===========================================
# ⚙️ ตัวอย่างการตั้งค่า Environment Variables
# ===========================================

# สำหรับ Production (Render.com/Railway/Heroku)
# ----------------------------------------------
# ใช้ DATABASE_URL แบบ connection string เดียว
DATABASE_URL=postgresql://attendance_user:password@dpg-xxx-a.singapore-postgres.render.com/attendance_db

# สำหรับ Local Development
# ----------------------------------------------
# ใช้ credentials แยก (ถ้าไม่มี DATABASE_URL)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_db

# Server Configuration
# ----------------------------------------------
PORT=3000
NODE_ENV=development

# ===========================================
# 📝 หมายเหตุ:
# ===========================================
# 1. ใช้ DATABASE_URL สำหรับ Render, Railway, Heroku
# 2. ใช้ DB_* variables สำหรับ local PostgreSQL
# 3. ระบบจะเลือก DATABASE_URL ก่อน ถ้าไม่มีจึงใช้ DB_*
# 4. PORT จะถูก override โดย platform (Render ใช้ 10000)
# 5. NODE_ENV=production บน Render, development บน local
