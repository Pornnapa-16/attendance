# ===========================================
# ⚙️ ตัวอย่างการตั้งค่า Environment Variables
# ===========================================

# สำหรับ Production (Koyeb + Supabase)
# ----------------------------------------------
# ใช้ DATABASE_URL จาก Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:password@xxxx.supabase.co:5432/postgres

# สำหรับ Local Development
# ----------------------------------------------
# ใช้ credentials แยก (ถ้าไม่มี DATABASE_URL)
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=attendance_db

# Server Configuration
# ----------------------------------------------
PORT=3000
NODE_ENV=development

# ===========================================
# 📝 หมายเหตุ:
# ===========================================
# 1. DATABASE_URL: ใช้สำหรับ Koyeb, Railway, Render, Heroku
# 2. DB_* variables: ใช้เฉพาะ Local Development
# 3. ระบบจะเลือก DATABASE_URL ก่อน ถ้าไม่มีจึงใช้ DB_*
# 4. PORT ใน Production จะถูก override โดย platform
# 5. NODE_ENV=production สำหรับ Production, development สำหรับ Local
#
# Supabase DATABASE_URL Format:
# postgresql://postgres:PASSWORD@PROJECT.supabase.co:5432/postgres
# (ดูวิธีได้ใน SUPABASE_SETUP.md)
